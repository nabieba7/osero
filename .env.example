# Osero Environment Variables
# Copy this file to .env and fill in the values

# Server port (default: 3000)
PORT=3000

# JWT secret — REQUIRED in production. Use a long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Admin API key — optional. If not set, admin endpoints are disabled.
ADMIN_KEY=

# Railway volume path (auto-set on Railway, defaults to project dir)
# RAILWAY_VOLUME_MOUNT_PATH=
