<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Osero — Play Othello (Reversi) online with AI, friends, or players worldwide. Free web game with leaderboard and accounts.">
<meta name="keywords" content="othello, reversi, osero, board game, online game, multiplayer">
<meta property="og:title" content="Osero — Othello Online">
<meta property="og:description" content="Play Othello (Reversi) online with AI, friends, or players worldwide.">
<meta property="og:type" content="website">
<meta property="og:url" content="https://osero-reverse.com">
  <title>Osero — Othello</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="./style.css">

</head>
<body>

  <!-- ═══════ MENU SCREEN ═══════ -->
  <div id="menu-screen" class="screen active">
    <div class="menu-container">
      <h1 class="menu-title">⚫ Osero ⚪</h1>
      <p class="menu-subtitle">The classic game of Reversi</p>

      <!-- Auth status bar -->
      <div id="auth-status" class="auth-status">
        <div id="auth-logged-out" class="auth-logged-out">
          <button class="menu-btn auth-btn" onclick="UI.showLogin()">🔑 Login</button>
          <button class="menu-btn auth-btn secondary" onclick="UI.showRegister()">✨ Sign Up</button>
        </div>
        <div id="auth-logged-in" class="auth-logged-in" style="display:none">
          <span class="user-avatar" id="menu-avatar">⚪</span>
          <span class="user-greeting" id="menu-greeting">Player</span>
          <button class="icon-btn" onclick="UI.showProfile()" title="Profile">👤</button>
          <button class="icon-btn" onclick="Auth.logout()" title="Logout">🚪</button>
        </div>
      </div>

      <div class="menu-section">
        <h2>vs AI</h2>
        <button class="menu-btn black-btn" onclick="Game.start('ai', 'black')">
          ⚫ Play as Black
        </button>
        <button class="menu-btn white-btn" onclick="Game.start('ai', 'white')">
          ⚪ Play as White
        </button>
      </div>

      <div class="menu-section">
        <h2>vs Player</h2>
        <button class="menu-btn local-btn" onclick="Game.start('pvp')">
          👥 Local 2-Player
        </button>
      </div>
      <div class="menu-section">
        <h2>Online</h2>
        <button class="menu-btn online-btn" onclick="UI.showOnlineMenu()">
          🌍 Play Online
        </button>
      </div>

      <div class="menu-section">
        <h2>Rankings</h2>
        <button class="menu-btn leaderboard-btn" onclick="UI.showLeaderboard()">
          🏆 Leaderboard
        </button>
      </div>

      <button class="rules-btn" onclick="UI.showRules()">❓ Rules</button>
      <button class="theme-toggle-menu" onclick="UI.toggleTheme()">🌙 Theme</button>

      <div class="menu-section">
        <label class="difficulty-label">AI Difficulty</label>
        <div class="difficulty-select">
          <button class="diff-btn" data-depth="2" onclick="Game.setDifficulty(this)">Easy</button>
          <button class="diff-btn active" data-depth="4" onclick="Game.setDifficulty(this)">Medium</button>
          <button class="diff-btn" data-depth="6" onclick="Game.setDifficulty(this)">Hard</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════ GAME SCREEN ═══════ -->
  <div id="game-screen" class="screen">
    <div class="game-container">

      <!-- Top bar -->
      <div class="top-bar">
        <button class="icon-btn" onclick="Game.backToMenu()" title="Back to Menu">← Menu</button>
        <div class="turn-indicator" id="turn-indicator">
          <span class="turn-disc black-disc-small"></span>
          <span id="turn-text">Black's turn</span>
        </div>
        <div class="top-bar-right">
          <button class="icon-btn" onclick="UI.toggleTheme()" id="theme-btn" title="Toggle theme">🌙</button>
          <button class="icon-btn" onclick="UI.toggleHints()" id="hints-btn" title="Toggle hints">👁</button>
          <button class="icon-btn" onclick="Game.restart()" title="Restart">↻</button>
        </div>
      </div>

      <!-- Scoreboard -->
      <div class="scoreboard">
        <div class="score black-score">
          <div class="score-disc black-disc-small"></div>
          <span class="score-label">Black</span>
          <span class="score-count" id="black-count">2</span>
        </div>
        <div class="score-divider">vs</div>
        <div class="score white-score">
          <div class="score-disc white-disc-small"></div>
          <span class="score-label">White</span>
          <span class="score-count" id="white-count">2</span>
        </div>
      </div>

      <!-- Board area -->
      <div class="board-wrapper">
        <div class="col-labels">
          <div class="corner-spacer"></div>
          <span>A</span><span>B</span><span>C</span><span>D</span>
          <span>E</span><span>F</span><span>G</span><span>H</span>
        </div>
        <div class="board-row-wrapper">
          <div class="row-labels">
            <span>1</span><span>2</span><span>3</span><span>4</span>
            <span>5</span><span>6</span><span>7</span><span>8</span>
          </div>
          <div class="board" id="board"></div>
        </div>
      </div>

      <!-- AI comment bubble -->
      <div class="ai-comment" id="ai-comment"></div>

      <!-- Move log -->
      <div class="move-log-container">
        <button class="move-log-toggle" onclick="UI.toggleMoveLog()">📝 Move Log</button>
        <div class="move-log" id="move-log" style="display:none;"></div>
      </div>

    </div>
  </div>

  <!-- ═══════ LEADERBOARD SCREEN ═══════ -->
  <div id="leaderboard-screen" class="screen">
    <div class="leaderboard-container">
      <div class="leaderboard-header">
        <button class="icon-btn" onclick="UI.showScreen('menu-screen')">← Back</button>
        <h1>🏆 Leaderboard</h1>
        <div style="width:70px"></div>
      </div>
      <p class="leaderboard-subtitle">Top players — minimum 5 games to rank</p>
      <div id="leaderboard-table" class="leaderboard-table">
        <div class="lb-loading">Loading...</div>
      </div>
    </div>
  </div>

  <!-- ═══════ PROFILE SCREEN ═══════ -->
  <div id="profile-screen" class="screen">
    <div class="profile-container">
      <div class="profile-header">
        <button class="icon-btn" onclick="UI.showScreen('menu-screen')">← Back</button>
        <h1>👤 Profile</h1>
        <div style="width:70px"></div>
      </div>
      <div id="profile-content" class="profile-content">
        <div class="profile-avatar-large" id="profile-avatar-large">⚪</div>
        <h2 id="profile-display-name">Player</h2>
        <p class="profile-username" id="profile-username">@username</p>

        <div class="profile-stats" id="profile-stats">
          <div class="stat-card">
            <span class="stat-value" id="stat-total">0</span>
            <span class="stat-label">Games</span>
          </div>
          <div class="stat-card stat-win">
            <span class="stat-value" id="stat-wins">0</span>
            <span class="stat-label">Wins</span>
          </div>
          <div class="stat-card stat-loss">
            <span class="stat-value" id="stat-losses">0</span>
            <span class="stat-label">Losses</span>
          </div>
          <div class="stat-card stat-draw">
            <span class="stat-value" id="stat-draws">0</span>
            <span class="stat-label">Draws</span>
          </div>
        </div>

        <div class="profile-rank" id="profile-rank-section" style="display:none">
          <span class="rank-label">Rank</span>
          <span class="rank-value" id="stat-rank">#—</span>
          <span class="winrate-label">Win Rate</span>
          <span class="winrate-value" id="stat-winrate">0%</span>
        </div>

        <div class="profile-recent">
          <h3>Recent Games</h3>
          <div id="profile-recent-list" class="recent-games-list">No games yet</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════ GAME OVER OVERLAY ═══════ -->
  <div class="overlay" id="game-over-overlay">
    <div class="overlay-card">
      <h2 id="game-over-title">Game Over</h2>
      <p class="final-score" id="final-score">32 — 32</p>
      <p class="game-result" id="game-result">Draw!</p>
      <p class="save-hint" id="save-hint" style="display:none">💡 <a href="#" onclick="UI.showLogin(); return false;">Login</a> to save your games!</p>
      <div class="overlay-actions">
        <button class="menu-btn black-btn" onclick="Game.restart()">Play Again</button>
        <button class="menu-btn local-btn" onclick="Game.backToMenu()">Main Menu</button>
      </div>
    </div>
  </div>

  <!-- ═══════ RULES MODAL ═══════ -->
  <div class="overlay" id="rules-overlay">
    <div class="overlay-card rules-card">
      <h2>❓ How to Play Osero</h2>
      <div class="rules-content">
        <p><strong>Osero</strong> (also called Othello or Reversi) is a strategy game for two players on an 8×8 board.</p>
        <h3>🎯 Goal</h3>
        <p>Have the most discs of your color when the game ends.</p>
        <h3>⚙️ Rules</h3>
        <ul>
          <li><strong>Black always goes first.</strong></li>
          <li>To place a disc, you must <strong>sandwich</strong> at least one opponent disc between your new disc and another of your own — in a straight line (horizontal, vertical, or diagonal).</li>
          <li>All sandwiched discs in <em>every</em> valid direction <strong>flip</strong> to your color at once.</li>
          <li>A move is only legal if it flips at least one disc.</li>
          <li>If you have <strong>no legal moves</strong>, your turn is <strong>skipped</strong> — you don't lose!</li>
          <li>If <strong>neither</strong> player can move, the game ends immediately.</li>
          <li>The game also ends when the board is full.</li>
        </ul>
        <h3>🏆 Winning</h3>
        <p>The player with the most discs wins. Equal count = draw.</p>
        <h3>💡 Pro Tip</h3>
        <p class="pro-tip"><strong>Corners are king.</strong> A disc in a corner can never be flipped. Never give one up — and always try to take one.</p>
      </div>
      <button class="menu-btn black-btn" onclick="UI.hideRules()">Got it!</button>
    </div>
  </div>

  <!-- ═══════ LOGIN MODAL ═══════ -->
  <div class="overlay" id="login-overlay">
    <div class="overlay-card">
      <h2>🔑 Login</h2>
      <input type="text" id="login-username" class="text-input" placeholder="Username" maxlength="20" autocomplete="username">
      <input type="password" id="login-password" class="text-input" placeholder="Password" autocomplete="current-password">
      <button class="menu-btn black-btn" onclick="Auth.login()" id="login-btn">Login</button>
      <p class="auth-switch">Don't have an account? <a href="#" onclick="UI.showRegister(); return false;">Sign up</a></p>
      <p class="auth-error" id="login-error"></p>
      <button class="menu-btn local-btn" onclick="UI.hideLogin()" style="margin-top:0.5rem;background:transparent;border-color:var(--card-border)">Cancel</button>
    </div>
  </div>

  <!-- ═══════ REGISTER MODAL ═══════ -->
  <div class="overlay" id="register-overlay">
    <div class="overlay-card">
      <h2>✨ Sign Up</h2>
      <input type="text" id="register-username" class="text-input" placeholder="Username (3-20 chars)" maxlength="20" autocomplete="username">
      <input type="text" id="register-display" class="text-input" placeholder="Display name (optional)" maxlength="30">
      <input type="password" id="register-password" class="text-input" placeholder="Password (4+ chars)" autocomplete="new-password">
      <input type="password" id="register-password2" class="text-input" placeholder="Confirm password" autocomplete="new-password">
      <button class="menu-btn black-btn" onclick="Auth.register()" id="register-btn">Create Account</button>
      <p class="auth-switch">Already have an account? <a href="#" onclick="UI.showLogin(); return false;">Login</a></p>
      <p class="auth-error" id="register-error"></p>
      <button class="menu-btn local-btn" onclick="UI.hideRegister()" style="margin-top:0.5rem;background:transparent;border-color:var(--card-border)">Cancel</button>
    </div>
  </div>

  <!-- ═══════ ONLINE MENU MODAL ═══════ -->
  <div class="overlay" id="online-menu-overlay">
    <div class="overlay-card">
      <h2>🌍 Play Online</h2>
      <input type="text" id="online-nickname" class="text-input" placeholder="Your nickname" maxlength="16">
      <div class="online-section">
        <button class="menu-btn local-btn" onclick="OnlineGame.createRoom()">🏠 Create Room</button>
      </div>
      <div class="online-divider">— or join —</div>
      <div class="online-section">
        <input type="text" id="join-room-code" class="text-input" placeholder="Room code (e.g. FROG3)" maxlength="8" style="text-transform:uppercase">
        <button class="menu-btn black-btn" onclick="OnlineGame.joinRoom()" style="margin-top:0.5rem">➡️ Join Room</button>
      </div>
      <button class="menu-btn local-btn" onclick="UI.hideOnlineMenu()" style="margin-top:0.75rem;background:transparent;border-color:var(--card-border)">Cancel</button>
      <p id="online-error" class="online-error"></p>
    </div>
  </div>

  <!-- ═══════ WAITING ROOM OVERLAY ═══════ -->
  <div class="overlay" id="waiting-overlay">
    <div class="overlay-card">
      <h2>🏠 Waiting for opponent</h2>
      <p class="waiting-info">Share this code with your friend:</p>
      <div class="room-code" id="room-code-display">----</div>
      <p class="waiting-sub" id="waiting-subtitle">You are ⚫ Black</p>
      <div class="waiting-spinner"></div>
      <button class="menu-btn local-btn" onclick="OnlineGame.cancelRoom()" style="margin-top:1rem;background:transparent;border-color:var(--card-border)">Cancel</button>
    </div>
  </div>

  <!-- ═══════ IN-GAME CHAT ═══════ -->
  <div class="chat-panel" id="chat-panel" style="display:none">
    <div class="chat-messages" id="chat-messages"></div>
    <div class="chat-input-row">
      <input type="text" id="chat-input" class="text-input" placeholder="Type a message..." maxlength="100">
      <button class="icon-btn" onclick="OnlineGame.sendChat()">Send</button>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="auth.js"></script>
  <script src="game.js"></script>
</body>
</html>
